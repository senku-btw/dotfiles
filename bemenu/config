# ~/.config/bemenu/config
# Paranoid Performance Profile: Single-line horizontal dmenu architecture
backend = wayland
ignorecase = true

# Pure Horizontal Mode: Setting lines to 0 enforces classic top-bar dmenu layout
lines = 0

# Visual Constraints (Adjust font size to keep it sharp and lightweight)
font = Monospace 10
line-height = 20

# Suckless/Dmenu Minimalist Aesthetic Color Matrix
title-background = #222222
title-foreground = #bbbbbb
filter-background = #222222
filter-foreground = #bbbbbb
normal-background = #222222
normal-foreground = #bbbbbb
highlight-background = #005577
highlight-foreground = #eeeeee
selected-background = #005577
selected-foreground = #eeeeee
scrollbar = none
